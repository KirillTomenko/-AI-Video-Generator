# === API Settings ===
# Замените на ваш реальный ключ API-агрегатора (piapi.ai, gen-api.ru и т.д.)
API_KEY=your_api_key_here

# Base URL вашего API-агрегатора:
#   piapi.ai  → https://api.piapi.ai
#   gen-api.ru → https://api.gen-api.ru
#   proxyapi  → https://api.proxyapi.ru  (укажите свой)
API_BASE_URL=https://api.piapi.ai

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# === Flask ===
FLASK_SECRET_KEY=change_this_secret
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# === Default Model ===
# Самые экономичные модели для коротких роликов:
#   ltx-video-fast   — дешевле всего, поддерживает 2-5 сек
#   wan-2.1-turbo    — $0.08/сек, быстрая генерация
#   kling-v1-standard — $0.14/5 сек, стабильное качество
DEFAULT_MODEL=ltx-video-fast
DEFAULT_DURATION=3
DEFAULT_RESOLUTION=720p
